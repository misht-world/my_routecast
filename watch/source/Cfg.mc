// Демо-настройки для симулятора. На железе (Gate 4) выставить в false:
// тогда маршрут приходит с телефона, а движение — из реального GPS часов.
module Cfg {
    const DEMO_AUTOLOAD = true; // авто-загрузка мок-маршрута при старте (без телефона)
    const DEMO_MOVE = true;     // авто-движение по маршруту (нет GPS-плеера в симуляторе)
}
